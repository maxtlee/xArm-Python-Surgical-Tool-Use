<mujoco model="surgical_sim">
  <compiler angle="radian" meshdir="../urdf/meshes"/>

  <option timestep="0.002" integrator="implicitfast"/>

  <visual>
    <headlight ambient="0.5 0.5 0.5"/>
  </visual>

  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.2 0.2 0.2" rgb2="0.3 0.3 0.3" width="512" height="512"/>
    <material name="grid" texture="grid" texrepeat="10 10" texuniform="true" reflectance="0.1"/>
  </asset>

  <worldbody>
    <!-- Floor -->
    <geom name="floor" type="plane" size="2 2 0.1" material="grid" condim="3"/>

    <light pos="0.5 0.5 2" dir="0 0 -1" directional="false"/>

    <!-- xArm6 placeholder stub - replace with real URDF via:
         python -m mujoco.mjcf urdf/xarm6.urdf > urdf/xarm6.xml
         then include it here with: <include file="../urdf/xarm6.xml"/>
    -->
    <body name="xarm_base" pos="0 0 0">
      <!-- Base link -->
      <geom name="base" type="cylinder" size="0.08 0.05" rgba="0.3 0.3 0.3 1"/>

      <!-- Link 1 -->
      <body name="link1" pos="0 0 0.05">
        <joint name="joint1" type="hinge" axis="0 0 1" range="-6.28 6.28"/>
        <geom name="link1" type="capsule" size="0.04 0.1" rgba="0.6 0.6 0.6 1"/>

        <!-- Link 2 -->
        <body name="link2" pos="0 0 0.15">
          <joint name="joint2" type="hinge" axis="0 1 0" range="-2.09 2.09"/>
          <geom name="link2" type="capsule" size="0.035 0.15" rgba="0.7 0.7 0.7 1"/>

          <!-- Link 3 -->
          <body name="link3" pos="0 0 0.2">
            <joint name="joint3" type="hinge" axis="0 1 0" range="-6.28 6.28"/>
            <geom name="link3" type="capsule" size="0.03 0.1" rgba="0.6 0.6 0.6 1"/>

            <!-- Link 4 -->
            <body name="link4" pos="0 0 0.15">
              <joint name="joint4" type="hinge" axis="1 0 0" range="-6.28 6.28"/>
              <geom name="link4" type="capsule" size="0.025 0.08" rgba="0.7 0.7 0.7 1"/>

              <!-- Link 5 -->
              <body name="link5" pos="0 0 0.1">
                <joint name="joint5" type="hinge" axis="0 1 0" range="-2.09 2.09"/>
                <geom name="link5" type="capsule" size="0.02 0.07" rgba="0.6 0.6 0.6 1"/>

                <!-- Link 6 / End effector -->
                <body name="link_eef" pos="0 0 0.08">
                  <joint name="joint6" type="hinge" axis="1 0 0" range="-6.28 6.28"/>
                  <geom name="link_eef" type="box" size="0.03 0.03 0.02" rgba="0.8 0.8 0.8 1"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>

    <!-- Soft foam hand (flexcomp placeholder) -->
    <flexcomp name="foam_hand" type="box" count="4 4 2" spacing="0.025 0.025 0.025" pos="0.3 0 0.25" rgba="0.9 0.6 0.4 1">
      <edge damping="0.5"/>
      <elasticity young="10000" poisson="0.4" damping="0.002"/>
      <contact condim="3" selfcollide="none"/>
    </flexcomp>

    <!-- Deformable tissue surface -->
    <flexcomp name="tissue" type="grid" count="16 16 1" spacing="0.020 0.020 0.020" pos="0.3 0 0.05" rgba="0.9 0.75 0.7 0.9">
      <edge damping="1.0"/>
      <elasticity young="100000" poisson="0.45" damping="0.005"/>
      <contact condim="3" selfcollide="none"/>
    </flexcomp>
  </worldbody>
</mujoco>
